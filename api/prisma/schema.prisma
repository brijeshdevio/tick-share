generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  files        File[]

  @@index([createdAt])
}

model File {
  id            String         @id @default(uuid()) // internal DB id
  publicId      String         @unique // nanoid(12-16), exposed in URL

  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  originalName  String
  storageKey    String         // S3/local storage reference
  mimeType      String
  size          Int

  visibility    FileVisibility @default(PRIVATE)

  expiresAt     DateTime
  downloadCount Int            @default(0)
  maxDownloads  Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Indexing strategy (very important)
  @@index([ownerId])
  @@index([visibility])
  @@index([expiresAt])
  @@index([ownerId, visibility])
  @@index([visibility, expiresAt])
}                                                                                                                                       