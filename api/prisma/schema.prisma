generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String

  files        File[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model File {
  id          String         @id @default(uuid())
  hashKey     String         @unique
  name        String
  size        Int
  mimeType    String
  storageId   String
  description String?

  visibility  FileVisibility @default(PUBLIC)

  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, visibility])
  @@index([userId, expiresAt])
}