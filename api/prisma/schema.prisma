generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files File[]

  @@index([email])
}

model File {
  id         String @id @default(uuid())
  shareToken String @unique

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  originalName String
  storageId    String
  mimeType     String
  sizeBytes    Int

  expiresAt     DateTime
  softDeletedAt DateTime?

  downloadCount Int  @default(0)
  maxDownloads  Int?

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([expiresAt, shareToken])
  @@index([shareToken])
}
